# Ignore everything, whitelist only project files
/*
!.gitignore
!README.md
!.github/
!app.js
!bot.js
!package.json
!package-lock.json
!.env.example
!bot/
!ai/
!db/
!dashboard/
!scripts/
!src/

# ============================================================
# Environment & Secrets
# ============================================================
.env
.env.*
!.env.example
*.key
*.pem
secrets/

# ============================================================
# Node.js
# ============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================================
# Database
# ============================================================
*.sqlite
*.sqlite3
*.db

# ============================================================
# Logs
# ============================================================
logs/
*.log

# ============================================================
# OS
# ============================================================
.DS_Store
Thumbs.db
Desktop.ini

# ============================================================
# IDE / Editors
# ============================================================
.vscode/
.idea/
*.swp
*.swo

# ============================================================
# Temp / Cache
# ============================================================
tmp/
.tmp/
*.tmp
*.bak
